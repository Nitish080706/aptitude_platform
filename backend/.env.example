# Copy this file to .env and fill in real values. Never commit .env.

# Secret key for admin account creation
ADMIN_SIGNUP_KEY=your-secret-admin-key-here

# Path to Firebase service account JSON (used locally)
FIREBASE_CREDENTIALS_PATH=./serviceAccountKey.json

# OR base64-encoded JSON or raw JSON string of your Firebase service account key (highly recommended for production/Render)
FIREBASE_CREDENTIALS_JSON=

# CORS origins for the frontend (comma-separated list for multiple origins)
CORS_ORIGINS=http://localhost:5500,https://Nitish080706.github.io
